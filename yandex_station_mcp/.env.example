# Скопируйте в yandex_station_mcp\.env и заполните после авторизации.
# Не коммитьте .env и yandex_tokens.json.

# Путь к локальному файлу токенов, который создает auth_qr.py.
YANDEX_TOKEN_FILE=yandex_station_mcp/yandex_tokens.json

# Необязательно: ID станции по умолчанию. Если не задан, берется первая найденная.
YANDEX_STATION_ID=

# Необязательно: домен Яндекса, если нужен не yandex.ru.
YANDEX_DOMAIN=
